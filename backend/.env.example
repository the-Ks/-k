# Generic AI provider config. Use these for commercial deployment.
AI_PROVIDER=deepseek
AI_API_KEY=your_ai_provider_api_key_here
AI_MODEL=deepseek-v4-flash
AI_BASE_URL=https://api.deepseek.com
AI_TIMEOUT_MS=120000
AI_THINKING=disabled

# Backward-compatible DeepSeek test-provider config.
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

AUTH_TOKEN_SECRET=replace_with_a_long_random_secret
AUTH_TOKEN_TTL_SECONDS=28800

PORT=8787
CORS_ORIGIN=*

DATA_SOURCE=mock
DATABASE_URL=postgres://postgres:postgres@localhost:5432/quality_inspection
DATABASE_SSL=false
DATABASE_POOL_MAX=10
ALLOW_MOCK_FALLBACK=false
